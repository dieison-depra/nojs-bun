                      "name": "v3_code_txt",
                      "fill": "#E2E8F0",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "<!DOCTYPE html>\n<html>\n<head>\n  <script src=\"https://cdn.no-js.dev/\"></script>\n</head>\n<body>\n  <div state=\"{ count: 0 }\">\n    <h1 bind=\"'Counter: ' + count\"></h1>\n    <button on:click=\"count++\">Increment</button>\n    <button on:click=\"count--\">Decrement</button>\n  </div>\n</body>\n</html>",
