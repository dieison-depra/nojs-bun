                  "layout": "vertical",
                  "gap": 20,
                  "children": [
                    {
                      "type": "text",
                      "id": "qDT5T",
                      "name": "quickTitle",
                      "fill": "#0F172A",
                      "content": "Quick Start",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 32,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "vPYtC",
                      "name": "quickIntro",
                      "fill": "#334155",
                      "content": "Create your first reactive page:",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "id": "owmHr",
                      "type": "ref",
                      "ref": "zDasK",
                      "width": "fill_container",
                      "name": "quickCode",
                      "height": "fit_content",
                      "y": 108,
                      "descendants": {
                        "salq5": {
                          "content": "<div state=\"{ count: 0 }\">",
                          "x": 28,
                          "y": 24
                        },
                        "IAMDC": {
                          "content": "  <p>Count: <span bind=\"count\"></span></p>",
                          "x": 28,
                          "y": 49
                        },
                        "qfwvk": {
                          "content": "  <button on:click=\"count++\">+</button>\n</div>",
                          "x": 28,
                          "y": 74
                        }
                      }
                    },
                    {
                      "type": "text",
                      "id": "IQEyW",
                      "name": "quickOutro",
                      "fill": "#334155",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "That's it! No JavaScript files needed. The state attribute creates reactive state, bind displays data, and on:click handles events — all directly in your HTML.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
