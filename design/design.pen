                            {
                              "type": "text",
                              "id": "XcjCM",
                              "name": "q12t",
                              "fill": "#0F172A",
                              "content": "How do I handle form validation?",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "thWmd",
                              "name": "q12i",
                              "fill": "#0EA5E9",
                              "content": "−",
                              "fontFamily": "Inter",
                              "fontSize": 24,
