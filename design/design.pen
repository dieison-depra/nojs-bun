          ],
          "children": [
            {
              "type": "text",
              "id": "dw68z",
              "name": "v5_kicker",
              "fill": "#475569",
              "content": "A MANIFESTO",
              "fontFamily": "Space Grotesk",
              "fontSize": 12,
              "fontWeight": "700",
              "letterSpacing": 4
            },
            {
              "type": "text",
              "id": "zlyAp",
              "name": "v5_h1",
              "fill": "#FFFFFF",
              "textGrowth": "fixed-width",
              "width": 900,
              "content": "The web was already reactive.",
              "fontFamily": "Space Grotesk",
              "fontSize": 64,
              "fontWeight": "bold",
              "letterSpacing": -3
            },
            {
              "type": "text",
              "id": "Bw08M",
              "name": "v5_h2",
              "fill": "#0EA5E9",
              "textGrowth": "fixed-width",
              "width": 800,
              "content": "We just gave HTML the attributes to prove it.",
              "fontFamily": "Space Grotesk",
              "fontSize": 36,
              "fontWeight": "normal",
              "letterSpacing": -1
            },
            {
              "type": "frame",
              "id": "KNDi9",
              "name": "v5_divider",
              "width": 120,
              "height": 3,
              "fill": "#0EA5E9"
            }
          ]
        },
        {
          "type": "frame",
          "id": "sA4GU",
          "name": "prob7",
          "width": "fill_container",
          "fill": "#0F172A",
          "stroke": {
            "thickness": {
              "top": 1
            },
            "fill": "#1E293B"
          },
          "layout": "vertical",
          "gap": 60,
          "padding": 80,
          "children": [
            {
              "type": "text",
              "id": "pqO9p",
              "name": "v5_ed_lbl",
              "fill": "#475569",
              "content": "THE PROBLEM WITH MODERN JAVASCRIPT",
              "fontFamily": "Space Grotesk",
              "fontSize": 11,
              "fontWeight": "700",
              "letterSpacing": 4
            },
            {
              "type": "frame",
              "id": "se9BF",
              "name": "Columns",
              "width": "fill_container",
              "gap": 48,
              "children": [
                {
                  "type": "frame",
                  "id": "dcT0W",
                  "name": "v5_col1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "ZKBRW",
                      "name": "v5_col1_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Somewhere between \"component thinking\" and \"virtual DOM diffing\", we forgot that the browser already understands HTML. It already knows how to update the DOM. It already handles events.\n\nWe built abstraction upon abstraction until a simple form required three files, a build pipeline, and a framework runtime.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "bkh82",
                  "name": "v5_col2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "O3s0D",
                      "name": "v5_col2_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "No.JS is the opposite bet. The browser is not the enemy — it's the platform. HTML is not limited — it's underutilized. Attributes are not primitive — they're a DSL waiting to happen.\n\nWe built No.JS on one conviction: if you can express it in HTML, you should.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "X4bqf",
                  "name": "v5_col3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "pAVeb",
                      "name": "v5_col3_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The result is a framework you can learn in an afternoon and ship in 30 seconds. Not because we made it simple — but because the browser was already capable. We just got out of the way.\n\nThis is not anti-JavaScript. It's pro-HTML.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "3CQE8",
          "name": "prins7",
          "width": "fill_container",
          "fill": "#0A1020",
          "stroke": {
            "thickness": {
              "top": 1
            },
            "fill": "#1E293B"
          },
          "layout": "vertical",
          "gap": 48,
          "padding": 80,
          "children": [
            {
              "type": "text",
              "id": "Kuhf8",
              "name": "v5_pr_lbl",
              "fill": "#475569",
              "content": "OUR PRINCIPLES",
              "fontFamily": "Space Grotesk",
              "fontSize": 11,
              "fontWeight": "700",
              "letterSpacing": 4
            },
            {
              "type": "frame",
              "id": "A5J8u",
              "name": "v5_pr_row",
              "width": "fill_container",
              "gap": 24,
              "children": [
                {
                  "type": "frame",
                  "id": "9Eruq",
                  "name": "v5_p1",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "c6oFG",
                      "name": "v5_p1n",
                      "fill": "#0EA5E9",
                      "content": "01",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "eDv7D",
                      "name": "v5_p1t",
                      "fill": "#FFFFFF",
                      "content": "The browser is the platform",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "LcKf8",
                      "name": "v5_p1d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We don't abstract the browser. We extend HTML to use it fully.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "EfEaN",
                  "name": "v5_p2",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "HBKsO",
                      "name": "v5_p2n",
                      "fill": "#0EA5E9",
                      "content": "02",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cGSOf",
                      "name": "v5_p2t",
                      "fill": "#FFFFFF",
                      "content": "Complexity is the enemy",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "lnL2B",
                      "name": "v5_p2d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If a feature requires a build step to exist, it doesn't belong in No.JS.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "47e0i",
                  "name": "v5_p3",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "l2q48",
                      "name": "v5_p3n",
                      "fill": "#0EA5E9",
                      "content": "03",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "xyHY0",
                      "name": "v5_p3t",
                      "fill": "#FFFFFF",
                      "content": "HTML-first, forever",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "ZR9dh",
                      "name": "v5_p3d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Every directive is an HTML attribute. Your templates are valid HTML that any browser can read.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "0Vq63",
                  "name": "v5_p4",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
