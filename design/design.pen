            },
            {
              "type": "text",
              "id": "WppDq",
              "name": "v6_h3",
              "fill": "#0EA5E9",
              "content": "Maintain nothing.",
              "textAlign": "center",
              "fontFamily": "Space Grotesk",
              "fontSize": 80,
              "fontWeight": "bold",
              "letterSpacing": -3
            },
            {
              "type": "text",
              "id": "uHHsX",
              "name": "v6_sub",
              "fill": "#64748B",
              "textGrowth": "fixed-width",
              "width": 680,
              "content": "No.JS comes with 6 starter templates for the most common app patterns. Each one is a single HTML file.",
              "textAlign": "center",
