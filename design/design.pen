                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "<div state=\"{ query: '' }\"\n     get=\"/api/search?q={{ query }}\" as=\"results\">\n  <input model=\"query\" />\n  <li each=\"r in results\" bind=\"r.name\"></li>\n</div>",
                          "lineHeight": 1.7,
