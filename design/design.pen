                      "name": "infoCallout",
                      "width": "fill_container",
                      "height": "fit_content",
                      "y": 127,
                      "descendants": {
                        "ktk59": {
                          "content": "No.JS works directly in the browser with zero dependencies. At ~14KB gzipped, it's one of the lightest reactive frameworks available.",
                          "x": 20,
                          "y": 16
                        }
                      }
                    }
                  ]
