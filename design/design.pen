              "fontSize": 36,
              "fontWeight": "normal",
              "letterSpacing": -1
            },
            {
              "type": "frame",
              "id": "X8jrZ",
              "name": "v5_divider",
              "width": 120,
              "height": 3,
              "fill": "#0EA5E9"
            }
          ]
        },
        {
          "type": "frame",
          "id": "xFklp",
          "name": "prob8",
          "width": "fill_container",
          "fill": "#0F172A",
          "stroke": {
            "thickness": {
              "top": 1
            },
            "fill": "#1E293B"
          },
          "layout": "vertical",
          "gap": 60,
          "padding": 80,
          "children": [
            {
              "type": "text",
              "id": "gFo62",
              "name": "v5_ed_lbl",
              "fill": "#475569",
              "content": "THE PROBLEM WITH MODERN JAVASCRIPT",
              "fontFamily": "Space Grotesk",
              "fontSize": 11,
              "fontWeight": "700",
              "letterSpacing": 4
            },
            {
              "type": "frame",
              "id": "F0tpM",
              "name": "Columns",
              "width": "fill_container",
              "gap": 48,
              "children": [
                {
                  "type": "frame",
                  "id": "oUqJz",
                  "name": "v5_col1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "HXRBf",
                      "name": "v5_col1_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Somewhere between \"component thinking\" and \"virtual DOM diffing\", we forgot that the browser already understands HTML. It already knows how to update the DOM. It already handles events.\n\nWe built abstraction upon abstraction until a simple form required three files, a build pipeline, and a framework runtime.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "NNwwQ",
                  "name": "v5_col2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "hrwhn",
                      "name": "v5_col2_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "No.JS is the opposite bet. The browser is not the enemy — it's the platform. HTML is not limited — it's underutilized. Attributes are not primitive — they're a DSL waiting to happen.\n\nWe built No.JS on one conviction: if you can express it in HTML, you should.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "ZGjFi",
                  "name": "v5_col3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "PLBxG",
                      "name": "v5_col3_t",
                      "fill": "#94A3B8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The result is a framework you can learn in an afternoon and ship in 30 seconds. Not because we made it simple — but because the browser was already capable. We just got out of the way.\n\nThis is not anti-JavaScript. It's pro-HTML.",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "NT4ym",
          "name": "prins8",
          "width": "fill_container",
          "fill": "#0A1020",
          "stroke": {
            "thickness": {
              "top": 1
            },
            "fill": "#1E293B"
          },
          "layout": "vertical",
          "gap": 48,
          "padding": 80,
          "children": [
            {
              "type": "text",
              "id": "T2yrv",
              "name": "v5_pr_lbl",
              "fill": "#475569",
              "content": "OUR PRINCIPLES",
              "fontFamily": "Space Grotesk",
              "fontSize": 11,
              "fontWeight": "700",
              "letterSpacing": 4
            },
            {
              "type": "frame",
              "id": "Ftx8w",
              "name": "v5_pr_row",
              "width": "fill_container",
              "gap": 24,
              "children": [
                {
                  "type": "frame",
                  "id": "YvXg9",
                  "name": "v5_p1",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "78t0n",
                      "name": "v5_p1n",
                      "fill": "#0EA5E9",
                      "content": "01",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "GYmaH",
                      "name": "v5_p1t",
                      "fill": "#FFFFFF",
                      "content": "The browser is the platform",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "LJPsH",
                      "name": "v5_p1d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We don't abstract the browser. We extend HTML to use it fully.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "R5o3F",
                  "name": "v5_p2",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "ya8yQ",
                      "name": "v5_p2n",
                      "fill": "#0EA5E9",
                      "content": "02",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "XXyLI",
                      "name": "v5_p2t",
                      "fill": "#FFFFFF",
                      "content": "Complexity is the enemy",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "pTuqs",
                      "name": "v5_p2d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If a feature requires a build step to exist, it doesn't belong in No.JS.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "tGgLm",
                  "name": "v5_p3",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "cF2Pn",
                      "name": "v5_p3n",
                      "fill": "#0EA5E9",
                      "content": "03",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "dyreJ",
                      "name": "v5_p3t",
                      "fill": "#FFFFFF",
                      "content": "HTML-first, forever",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "L4kud",
                      "name": "v5_p3d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Every directive is an HTML attribute. Your templates are valid HTML that any browser can read.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "h8qKF",
                  "name": "v5_p4",
                  "width": "fill_container",
                  "fill": "#0F172A",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#1E293B"
                  },
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 28,
                  "children": [
                    {
                      "type": "text",
                      "id": "7YP95",
                      "name": "v5_p4n",
                      "fill": "#0EA5E9",
                      "content": "04",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "CS7lB",
                      "name": "v5_p4t",
                      "fill": "#FFFFFF",
                      "content": "Ship on day one",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "hUkac",
                      "name": "v5_p4d",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The best framework is the one you can use right now, without asking permission from a terminal.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
