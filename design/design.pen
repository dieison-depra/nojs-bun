                        },
                        {
                          "type": "text",
                          "id": "D0o1d",
                          "name": "q12a",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "No.JS provides declarative form validation through the :validate directive. You can define rules, custom error messages, and validation patterns directly in your HTML markup — including required fields, min/max length, email format, and custom regex.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    }
