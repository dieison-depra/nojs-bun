                          "name": "q1a",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "No.JS is an HTML-first reactive framework that lets you build dynamic web applications using only HTML attributes — no JavaScript compilation, no virtual DOM, no build step required. It weighs just 14 KB gzipped and provides reactivity, routing, data fetching, i18n, animations, and more out of the box.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 16,
