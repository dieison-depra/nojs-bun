                              "fill": "#0F172A",
                              "content": "How does No.JS compare to React or Vue?",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "GZrft",
                              "name": "q8i",
                              "fill": "#0EA5E9",
                              "content": "−",
                              "fontFamily": "Inter",
                              "fontSize": 24,
                              "fontWeight": "300"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "2oHF8",
                          "name": "q8a",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Unlike React or Vue, No.JS requires no build step, no virtual DOM, and no JavaScript files. You write everything in HTML attributes. The result is dramatically smaller bundles (14 KB vs 100+ KB) and simpler deployment — just ship HTML.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "zUpRM",
                  "name": "Features Section",
                  "width": "fill_container",
                  "fill": "#FFFFFF",
                  "layout": "vertical",
                  "padding": [
                    40,
                    0
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "o68xL",
                      "name": "cat3Title",
                      "fill": "#0F172A",
                      "content": "Features & Capabilities",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 28,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "frame",
                      "id": "coa1s",
                      "name": "divider",
                      "width": "fill_container",
                      "height": 1,
                      "fill": "#E2E8F0"
                    },
                    {
                      "type": "frame",
                      "id": "NMl95",
                      "name": "Q9 - Routing",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "padding": [
                        24,
                        0
                      ],
                      "children": [
                        {
                          "type": "frame",
                          "id": "OuPdj",
                          "name": "Question Row",
                          "width": "fill_container",
                          "justifyContent": "space_between",
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "text",
                              "id": "tfOES",
                              "name": "q9t",
                              "fill": "#0F172A",
                              "content": "Does No.JS support client-side routing?",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "Gqklt",
                              "name": "q9i",
                              "fill": "#0EA5E9",
                              "content": "−",
                              "fontFamily": "Inter",
                              "fontSize": 24,
                              "fontWeight": "300"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "44L1G",
                          "name": "q9a",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Yes. No.JS includes a built-in SPA router with support for path parameters, query strings, hash-based routing, and file-based route loading. Define routes with simple HTML attributes — no configuration files needed.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "RZ1iy",
                      "name": "divider",
                      "width": "fill_container",
                      "height": 1,
                      "fill": "#E2E8F0"
